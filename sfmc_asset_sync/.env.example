SFMC_AUTH_BASE_URL=https://YOUR_SUBDOMAIN.auth.marketingcloudapis.com
SFMC_REST_BASE_URL=https://YOUR_SUBDOMAIN.rest.marketingcloudapis.com
SFMC_CLIENT_ID=your_client_id
SFMC_CLIENT_SECRET=your_client_secret
SFMC_ACCOUNT_ID=

# Local git repository that will store SFMC assets
LOCAL_REPO_PATH=C:\path\to\sfmc-email-assets-repo

# Asset list file path (CSV or JSON) and output folder path (relative to LOCAL_REPO_PATH unless absolute)
ASSET_LIST_PATH=Assets.csv
OUTPUT_DIR=assets\html

# When true, pushes commit to current branch's upstream after commit
AUTO_PUSH=false

# When true, syncs are committed to a new branch (sfmc-sync-<timestamp>) which is
# pushed to origin, and a pull request is opened for review instead of committing
# directly to the current branch. Requires GITHUB_TOKEN.
CREATE_PULL_REQUEST=false

# GitHub personal access token used to open the pull request (needs 'repo' scope).
# Required when CREATE_PULL_REQUEST=true.
GITHUB_TOKEN=

# Optional: base branch to open the PR against. Defaults to the repo's current
# checked-out branch if left blank.
PR_BASE_BRANCH=

# Optional: full path to git.exe if it isn't on PATH (auto-detected otherwise).
GIT_EXECUTABLE=

# Optional: path to the log file (info/warning/error) written on every run.
LOG_FILE=sfmc_asset_sync.log

# Optional (only needed if repo doesn't already have git identity configured)
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
